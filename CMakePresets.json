{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "core",
      "displayName": "RayMMA core Release",
      "description": "CUDA-only benchmark and correctness tests",
      "binaryDir": "${sourceDir}/build/core",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "RAYMMA_BUILD_BENCHMARK": "ON",
        "RAYMMA_ENABLE_TINYBVH": "OFF",
        "RAYMMA_ENABLE_EXTERNAL_SCENES": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "core",
      "configurePreset": "core"
    }
  ],
  "testPresets": [
    {
      "name": "core",
      "configurePreset": "core",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
